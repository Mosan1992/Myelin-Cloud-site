:80 {
	root * /usr/share/caddy
	encode zstd gzip

	# Map clean URLs to Astro's directory-style output:
	# /about -> /about/index.html, / -> /index.html
	try_files {path} {path}/index.html {path}/ =404
	file_server

	# Hashed Astro assets are immutable; cache them hard.
	@assets path /_astro/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
}
