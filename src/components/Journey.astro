---
// The closed loop as a pinned scroll chapter (UAE-Pavilion-style
// storytelling): on desktop the section pins while the visitor scrolls
// through the four phases; the gold arc draws around the device core
// and each phase lights in turn. On mobile / reduced-motion it renders
// as a fully-visible static diagram — the markup below IS the final
// state, GSAP only dims and re-reveals it. Copy comes from home.loop
// so all three languages work with no new strings.
import { useT } from '../i18n/utils';
const t = useT(Astro.currentLocale).home;
const { no = '02' } = Astro.props;
const pos = [
  [210, 60],
  [360, 210],
  [210, 360],
  [60, 210],
];
---
<section class="journey dark" data-journey>
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-label"><span class="sec-no">{no}</span><span class="eyebrow">{t.solutionEyebrow}</span></div>
      <div class="sec-body">
        <h2>{t.solutionH2a}<span class="accent">{t.solutionAccent}</span></h2>
        <p class="lede">{t.solutionLede}</p>
      </div>
    </div>
    <div class="j-grid">
      <div class="j-steps">
        {t.loop.map((n) => (
          <div class="j-step">
            <div class="j-no">{n.n}</div>
            <div>
              <div class="j-s">{n.s}</div>
              <h3>{n.h}</h3>
              <p>{n.p}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="j-visual" aria-hidden="true">
        <svg viewBox="0 0 420 420" fill="none">
          <circle cx="210" cy="210" r="150" stroke="rgba(201,168,101,.16)" stroke-width="1.5" />
          <circle class="j-arc" cx="210" cy="210" r="150" stroke="#c9a865" stroke-width="2.5"
            stroke-linecap="round" transform="rotate(-90 210 210)" />
          <circle class="j-orbit" cx="210" cy="210" r="72" stroke="rgba(201,168,101,.22)" stroke-width="1" stroke-dasharray="3 8" />
          <circle class="j-pulse" cx="210" cy="210" r="28" stroke="rgba(201,168,101,.3)" stroke-width="1.5" />
          <circle cx="210" cy="210" r="11" fill="#c9a865" />
          {t.loop.map((n, i) => (
            <g class="j-node">
              <circle class="j-halo" cx={pos[i][0]} cy={pos[i][1]} r="31" stroke="#c9a865" stroke-width="2" opacity="0" />
              <circle cx={pos[i][0]} cy={pos[i][1]} r="26" fill="#221e18" stroke="rgba(201,168,101,.4)" stroke-width="1.5" />
              <text x={pos[i][0]} y={pos[i][1] + 5} text-anchor="middle" font-size="14" fill="#c9a865">{n.n}</text>
            </g>
          ))}
        </svg>
      </div>
    </div>
    <div class="j-loopback">{t.loopback}</div>
  </div>
</section>
