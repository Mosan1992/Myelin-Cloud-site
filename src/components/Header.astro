---
import { useT, getLang, localePath, altLangPath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useT(Astro.currentLocale);

let path = Astro.url.pathname;
if (path.startsWith('/en')) path = path.slice(3);
path = path.replace(/^\/+|\/+$/g, '');

const alt = altLangPath(lang, path);

const links = [
  { label: t.nav.about, p: 'about' },
  { label: t.nav.vision, p: 'vision' },
  { label: t.nav.technology, p: 'technology' },
  { label: t.nav.ip, p: 'ip' },
  { label: t.nav.contact, p: 'contact' },
];
---
<header>
  <div class="wrap">
    <nav>
      <a class="logo" href={localePath(lang, '')} aria-label={t.site.name}>
        <span class="mark"></span>
        <span>{t.site.name}<small>{t.site.sub}</small></span>
      </a>
      <div class="nav-right">
        <div class="nav-links">
          {links.map((l) => (
            <a href={localePath(lang, l.p)} class={path === l.p ? 'active' : ''}>{l.label}</a>
          ))}
        </div>
        <a class="toggle" href={alt.href} hreflang={alt.lang} rel="alternate">{t.site.switchTo}</a>
        <a class="btn" href={localePath(lang, 'contact')}>{t.nav.cta}</a>
      </div>
    </nav>
  </div>
</header>
