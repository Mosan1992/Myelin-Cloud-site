---
import { useT, getLang, localePath } from '../../i18n/utils';
const lang = getLang(Astro.currentLocale);
const t = useT(Astro.currentLocale).company;
---
<!-- HERO -->
<section class="hero">
  <div class="wrap">
    <span class="tag"><span class="dot"></span>{t.tag}</span>
    <h1>{t.h1a}<span class="accent">{t.h1accent}</span>{t.h1b}</h1>
    <p>{t.lede}</p>
    <div class="hero-cta">
      <a class="btn" href={localePath(lang, 'histo-cooling')}>{t.ctaPrimary}</a>
      <a class="btn ghost" href={localePath(lang, 'contact')}>{t.ctaGhost}</a>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<section class="alt reveal">
  <div class="wrap">
    <div class="eyebrow">{t.doEyebrow}</div>
    <h2>{t.doH2a}<span class="accent">{t.doAccent}</span></h2>
    <p class="lede">{t.doLede}</p>
    <div class="grid g4" style="margin-top:34px">
      {t.pillars.map((c) => (
        <div class="card"><h3>{c.h}</h3><p>{c.p}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- FLAGSHIP PROJECT -->
<section class="reveal">
  <div class="wrap">
    <div class="eyebrow">{t.projEyebrow}</div>
    <h2>{t.projH2a}<span class="accent">{t.projAccent}</span></h2>
    <p class="lede">{t.projLede}</p>
    <div class="hero-cta" style="margin-top:28px">
      <a class="btn" href={localePath(lang, 'histo-cooling')}>{t.projCta}</a>
    </div>
    <p class="note" style="margin-top:30px">{t.pipeline}</p>
  </div>
</section>

<!-- APPROACH -->
<section class="alt reveal">
  <div class="wrap">
    <div class="eyebrow">{t.approachEyebrow}</div>
    <h2>{t.approachH2a}<span class="accent">{t.approachAccent}</span></h2>
    <div class="grid g3" style="margin-top:34px">
      {t.approach.map((p) => (
        <div class="card"><h3>{p.h}</h3><p>{p.p}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT CTA -->
<section class="alt2 reveal">
  <div class="wrap">
    <div class="cta-box">
      <h2>{t.ctaH2}</h2>
      <p class="lede">{t.ctaLede}</p>
      <a class="btn" href={localePath(lang, 'contact')}>{t.ctaGhost}</a>
    </div>
  </div>
</section>
