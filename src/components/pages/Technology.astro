---
import { useT } from '../../i18n/utils';
import Journey from '../Journey.astro';
const t = useT(Astro.currentLocale).technology;
const home = useT(Astro.currentLocale).home;
---
<section class="page-hero">
  <div class="wrap">
    <div class="eyebrow">{t.eyebrow}</div>
    <h1>{t.h1a}<span class="accent">{t.h1accent}</span>{t.h1b}</h1>
    <p class="lede">{t.lede}</p>
  </div>
</section>

<section class="reveal">
  <div class="wrap">
    <figure class="figure">
      <img src="/device-concept.svg" alt="Histo-Cooling concept cross-section" loading="lazy" />
    </figure>
    <p class="figcap">{t.figcap}</p>
  </div>
</section>

<!-- closed loop -->
<Journey no="01" />

<!-- three layers -->
<section class="reveal">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-label"><span class="sec-no">02</span></div>
      <div class="sec-body"><h2>{t.layersH}</h2></div>
    </div>
    <div class="grid g3">
      {t.layersDetail.map((l) => (
        <div class="card"><div class="kicker">{l.tag}</div><h3>{l.h}</h3><p>{l.p}</p></div>
      ))}
    </div>
    <div class="specs">
      {t.specs.map((s) => <span class="spec">{s}</span>)}
    </div>
  </div>
</section>

<!-- data sovereignty -->
<section class="alt reveal">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-label"><span class="sec-no">03</span></div>
      <div class="sec-body"><h2>{t.sovereigntyH}</h2></div>
    </div>
    <div class="grid g2">
      {t.sovereignty.map((c) => (
        <div class="card"><h3>{c.h}</h3><p>{c.p}</p></div>
      ))}
    </div>
    <p class="note">{t.note}</p>
  </div>
</section>
