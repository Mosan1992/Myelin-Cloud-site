---
// Premium motion layer, bundled locally (no CDN — reliable in China):
// Lenis smooth scroll, GSAP scroll choreography, word-split hero
// reveals, stat counters, figure parallax, magnetic buttons, cursor
// glow on cards, and the neural hero canvas. Respects
// prefers-reduced-motion and re-initializes on view-transition
// navigations via astro:page-load.
---
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fine = matchMedia('(pointer:fine)').matches;

  /* ---------- persistent layer: bound once, survives page swaps ---------- */

  let lenis = null;
  if (!reduce) {
    lenis = new Lenis({ duration: 1.1, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
    const raf = (time) => { lenis.raf(time); requestAnimationFrame(raf); };
    requestAnimationFrame(raf);
    lenis.on('scroll', ScrollTrigger.update);
  }

  const onScroll = () => document.querySelector('header')?.classList.toggle('scrolled', window.scrollY > 10);
  addEventListener('scroll', onScroll, { passive: true });

  // Cursor-tracking glow on cards + magnetic buttons, delegated so new
  // DOM after a view transition needs no rebinding.
  const GLOW = '.card,.node,.arc .step,.ph,.stat,.fact,.cta-box';
  if (fine) {
    document.addEventListener('pointermove', (e) => {
      if (!(e.target instanceof Element)) return;
      const g = e.target.closest(GLOW);
      if (g) {
        const r = g.getBoundingClientRect();
        g.style.setProperty('--mx', (((e.clientX - r.left) / r.width) * 100).toFixed(2) + '%');
        g.style.setProperty('--my', (((e.clientY - r.top) / r.height) * 100).toFixed(2) + '%');
      }
      if (!reduce) {
        const b = e.target.closest('.btn');
        if (b) {
          const r = b.getBoundingClientRect();
          b.style.transform = `translate(${(e.clientX - r.left - r.width / 2) * 0.16}px,${(e.clientY - r.top - r.height / 2) * 0.26}px)`;
        }
      }
    }, { passive: true });
    document.addEventListener('pointerout', (e) => {
      if (!(e.target instanceof Element)) return;
      const b = e.target.closest('.btn');
      if (b && !(e.relatedTarget instanceof Element && e.relatedTarget.closest('.btn') === b)) b.style.transform = '';
    }, { passive: true });
  }

  document.addEventListener('click', (e) => {
    if (!(e.target instanceof Element)) return;
    const a = e.target.closest('a[href^="#"]');
    if (!a) return;
    const id = a.getAttribute('href');
    if (!id || id.length < 2) return;
    const el = document.querySelector(id);
    if (!el) return;
    e.preventDefault();
    if (lenis) lenis.scrollTo(el, { offset: -70 });
    else el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth' });
  });

  /* ---------- word / character splitting for headline reveals ---------- */

  const CJK = /[一-鿿]/;
  function splitWords(h) {
    const out = [];
    const wrap = (parent) => {
      [...parent.childNodes].forEach((n) => {
        if (n.nodeType === 3) {
          const frag = document.createDocumentFragment();
          n.textContent.split(/(\s+)/).forEach((part) => {
            if (!part) return;
            if (/^\s+$/.test(part)) { frag.append(document.createTextNode(part)); return; }
            // CJK has no spaces: reveal per character. Arabic stays
            // word-level so cursive joins are never broken.
            const pieces = CJK.test(part) ? [...part] : [part];
            pieces.forEach((piece) => {
              const s = document.createElement('span');
              s.className = 'wsplit';
              s.textContent = piece;
              out.push(s);
              frag.append(s);
            });
          });
          parent.replaceChild(frag, n);
        } else if (n.nodeType === 1) wrap(n);
      });
    };
    wrap(h);
    h.dataset.split = '1';
    return out;
  }

  /* ---------- neural network canvas (the "myelin" hero motif) ---------- */

  function neural(canvas) {
    if (canvas.dataset.init) return;
    canvas.dataset.init = '1';
    const ctx = canvas.getContext('2d');
    const host = canvas.parentElement;
    let w = 0, h = 0, nodes = [], running = false, raf = 0;
    const P = { x: -1e4, y: -1e4 };
    const LINK = 130, MOUSE = 170;

    function size() {
      const dpr = Math.min(2, devicePixelRatio || 1);
      w = host.clientWidth; h = host.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = Math.min(72, Math.round((w * h) / 16000));
      nodes = Array.from({ length: n }, () => ({
        x: Math.random() * w, y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.22, vy: (Math.random() - 0.5) * 0.22,
        r: 1 + Math.random() * 1.7,
      }));
      if (reduce) frame();
    }

    function frame() {
      ctx.clearRect(0, 0, w, h);
      for (const p of nodes) {
        p.x += p.vx; p.y += p.vy;
        if (p.x < -20) p.x = w + 20; else if (p.x > w + 20) p.x = -20;
        if (p.y < -20) p.y = h + 20; else if (p.y > h + 20) p.y = -20;
      }
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j];
          const dx = a.x - b.x, dy = a.y - b.y, d2 = dx * dx + dy * dy;
          if (d2 < LINK * LINK) {
            ctx.strokeStyle = `rgba(148,118,62,${(1 - Math.sqrt(d2) / LINK) * 0.16})`;
            ctx.lineWidth = 1;
            ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
          }
        }
        const dx = a.x - P.x, dy = a.y - P.y, d2 = dx * dx + dy * dy;
        if (d2 < MOUSE * MOUSE) {
          ctx.strokeStyle = `rgba(138,109,56,${(1 - Math.sqrt(d2) / MOUSE) * 0.3})`;
          ctx.lineWidth = 1;
          ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(P.x, P.y); ctx.stroke();
        }
        ctx.fillStyle = 'rgba(148,118,62,.5)';
        ctx.beginPath(); ctx.arc(a.x, a.y, a.r, 0, 6.2832); ctx.fill();
      }
    }

    const loop = () => { frame(); raf = requestAnimationFrame(loop); };
    const start = () => { if (!running) { running = true; raf = requestAnimationFrame(loop); } };
    const stop = () => { running = false; cancelAnimationFrame(raf); };

    size();
    new ResizeObserver(size).observe(host);
    if (reduce) return;
    new IntersectionObserver((es) => es.forEach((e) => (e.isIntersecting ? start() : stop()))).observe(host);
    const section = host.closest('section') || host;
    section.addEventListener('pointermove', (e) => {
      const r = canvas.getBoundingClientRect();
      P.x = e.clientX - r.left; P.y = e.clientY - r.top;
    }, { passive: true });
    section.addEventListener('pointerleave', () => { P.x = P.y = -1e4; }, { passive: true });
  }

  /* ---------- pinned scroll journey (closed-loop chapter) ---------- */

  function journey() {
    document.querySelectorAll('.journey[data-journey]').forEach((section) => {
      const steps = [...section.querySelectorAll('.j-step')];
      const nodes = [...section.querySelectorAll('.j-node')];
      const arc = section.querySelector('.j-arc');
      if (!steps.length) return;

      if (reduce || matchMedia('(max-width:900px)').matches) {
        steps.forEach((s) => s.classList.add('active'));
        nodes.forEach((n) => n.classList.add('active'));
        return;
      }

      const circ = arc ? arc.getTotalLength() : 0;
      if (arc) { arc.style.strokeDasharray = String(circ); arc.style.strokeDashoffset = String(circ); }
      let current = -1;
      ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: '+=' + steps.length * 320,
        pin: true,
        scrub: 0.6,
        onUpdate(self) {
          if (arc) arc.style.strokeDashoffset = String(circ * (1 - self.progress));
          const idx = Math.min(steps.length - 1, Math.floor(self.progress * steps.length));
          if (idx === current) return;
          current = idx;
          steps.forEach((s, i) => s.classList.toggle('active', i === idx));
          nodes.forEach((n, i) => n.classList.toggle('active', i === idx));
        },
      });
    });
  }

  /* ---------- ambient video loops: play only while on screen ---------- */

  function videos() {
    document.querySelectorAll('video[data-autoplay]').forEach((v) => {
      if (v.dataset.init) return;
      v.dataset.init = '1';
      if (reduce) return;
      new IntersectionObserver((es) => {
        es.forEach((e) => (e.isIntersecting ? v.play().catch(() => {}) : v.pause()));
      }, { threshold: 0.35 }).observe(v);
    });
  }

  /* ---------- per-page init (initial load + every view transition) ---------- */

  function initPage() {
    ScrollTrigger.getAll().forEach((st) => st.kill());
    onScroll();

    document.querySelectorAll('.reveal').forEach((el) => {
      ScrollTrigger.create({ trigger: el, start: 'top 84%', once: true, onEnter: () => el.classList.add('in') });
    });

    const h1 = document.querySelector('.hero h1,.page-hero h1');
    if (!reduce && h1 && !h1.dataset.split) {
      const words = splitWords(h1);
      gsap.timeline({ defaults: { ease: 'power3.out' } })
        .from(words, { opacity: 0, y: '0.55em', duration: 0.8, stagger: 0.045 }, 0.05)
        .from('.hero .tag,.hero p,.hero-cta,.page-hero .eyebrow,.page-hero .lede', {
          opacity: 0, y: 24, duration: 0.8, stagger: 0.1, clearProps: 'all',
        }, 0.3);
    }

    document.querySelectorAll('.stat .big').forEach((el) => {
      const m = (el.textContent || '').match(/^([^\d]*)([\d,.]+)([\s\S]*)$/);
      if (!m || el.dataset.count) return;
      el.dataset.count = '1';
      const end = parseFloat(m[2].replace(/,/g, ''));
      const dec = (m[2].split('.')[1] || '').length;
      ScrollTrigger.create({
        trigger: el, start: 'top 88%', once: true,
        onEnter: () => {
          if (reduce) return;
          const o = { v: 0 };
          gsap.to(o, { v: end, duration: 1.6, ease: 'power2.out', onUpdate: () => { el.textContent = m[1] + o.v.toFixed(dec) + m[3]; } });
        },
      });
    });

    if (!reduce) {
      document.querySelectorAll('.figure img').forEach((img) => {
        gsap.fromTo(img, { y: -14, scale: 1.06 }, {
          y: 14, scale: 1.06, ease: 'none',
          scrollTrigger: { trigger: img.closest('.figure'), scrub: 0.6, start: 'top bottom', end: 'bottom top' },
        });
      });
    }

    document.querySelectorAll('canvas.neural').forEach(neural);
    journey();
    videos();
  }

  document.addEventListener('astro:page-load', initPage);
</script>
