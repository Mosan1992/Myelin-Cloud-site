---
// Premium motion layer: smooth scroll + scroll-choreographed reveals +
// header condense + magnetic buttons. Loaded from a CDN; degrades
// gracefully (IntersectionObserver fallback) and respects reduced motion.
---
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js"></script>
<script is:inline>
  (function () {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hasGSAP = window.gsap && window.ScrollTrigger;
    let lenis = null;

    if (window.Lenis && !reduce) {
      lenis = new Lenis({ duration: 1.1, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      requestAnimationFrame(function raf(time) { lenis.raf(time); requestAnimationFrame(raf); });
    }

    if (hasGSAP) {
      gsap.registerPlugin(ScrollTrigger);
      if (lenis) lenis.on('scroll', ScrollTrigger.update);
      document.querySelectorAll('.reveal').forEach((el) => {
        ScrollTrigger.create({ trigger: el, start: 'top 84%', once: true, onEnter: () => el.classList.add('in') });
      });
      if (!reduce) {
        gsap.from('.hero .tag,.hero h1,.hero p,.hero-cta,.page-hero .eyebrow,.page-hero h1,.page-hero .lede', {
          opacity: 0, y: 26, duration: 0.9, ease: 'power3.out', stagger: 0.12, delay: 0.1,
        });
      }
    } else {
      const io = new IntersectionObserver((es) => es.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }), { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    }

    document.querySelectorAll('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href'); if (id.length < 2) return;
        const el = document.querySelector(id); if (!el) return;
        e.preventDefault();
        if (lenis) lenis.scrollTo(el, { offset: -70 });
        else el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth' });
      });
    });

    const header = document.querySelector('header');
    const onScroll = () => header && header.classList.toggle('scrolled', window.scrollY > 10);
    onScroll(); addEventListener('scroll', onScroll, { passive: true });

    if (!reduce && matchMedia('(pointer:fine)').matches) {
      document.querySelectorAll('.btn').forEach((btn) => {
        btn.addEventListener('mousemove', (e) => {
          const r = btn.getBoundingClientRect();
          btn.style.transform = `translate(${(e.clientX - r.left - r.width / 2) * 0.18}px,${(e.clientY - r.top - r.height / 2) * 0.28}px)`;
        });
        btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
      });
    }
  })();
</script>
