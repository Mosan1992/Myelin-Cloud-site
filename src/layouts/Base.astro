---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Motion from '../components/Motion.astro';
import { getLang, localePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;

const lang = getLang(Astro.currentLocale);
let path = Astro.url.pathname;
if (path.startsWith('/en')) path = path.slice(3);
path = path.replace(/^\/+|\/+$/g, '');

const origin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : '';
const zhHref = origin + localePath('zh', path);
const enHref = origin + localePath('en', path);
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={lang === 'en' ? enHref : zhHref} />
    <link rel="alternate" hreflang="zh-Hans" href={zhHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={zhHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <script is:inline>document.documentElement.classList.add('js')</script>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <Motion />
  </body>
</html>
